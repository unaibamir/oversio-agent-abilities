# Files and directories excluded from the WordPress.org build/deploy.
# Mirrors .gitattributes export-ignore; used by the release workflow's
# 10up/action-wordpress-plugin-deploy step.

/.git
/.github
/.ddev
/.claude
/tests
/bin
/wp
/public
/CLAUDE.md
/CONTRIBUTING.md
/.mcp.json
.DS_Store
/.phpunit.cache
/.playwright-cli
/.distignore
/.gitattributes
/.gitignore
/.editorconfig
/README.md
/composer.json
/composer.lock
/phpcs.xml.dist
/phpstan.neon.dist
/phpstan-baseline.neon
/phpunit.xml.dist

# Dev-only Composer dependencies. The release build runs `composer install --no-dev`,
# so these are normally absent when the tree is deployed; listed here as a backstop in
# case a dev install is ever staged for the build. The runtime deps that DO ship live in
# vendor/automattic, vendor/wordpress, vendor/jetpack-autoloader, and vendor/composer.
/vendor/bin
/vendor/dealerdirect
/vendor/doctrine
/vendor/myclabs
/vendor/nikic
/vendor/phar-io
/vendor/php-stubs
/vendor/phpcompatibility
/vendor/phpcsstandards
/vendor/phpstan
/vendor/phpunit
/vendor/sebastian
/vendor/squizlabs
/vendor/szepeviktor
/vendor/theseer
/vendor/wp-coding-standards
/vendor/yoast
